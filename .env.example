# SmarterContact Audit Automation - Environment Variables
# Copy this to .env and fill in your values

# Groq API Key (get from https://console.groq.com)
GROQ_API_KEY=your_groq_api_key_here

# Encryption key for agent credentials (auto-generated on first run)
CREDENTIALS_KEY=

# Browser Settings
MAX_PARALLEL_WORKERS=5
HEADLESS_MODE=true
SCREENSHOT_ON_ERROR=true

# Anti-Detection
MIN_DELAY_SECONDS=2
MAX_DELAY_SECONDS=5
MAX_RETRIES=3

# Database
DB_PATH=database/audit_data.db

# Logging
LOG_LEVEL=INFO
LOG_DIR=logs

# Alert Email (Phase 4)
ALERT_EMAIL=
SMTP_SERVER=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
